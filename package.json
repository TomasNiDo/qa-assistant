{
  "name": "qa-assistant",
  "version": "0.2.0-beta.2",
  "private": true,
  "description": "Local AI-powered QA Assistant desktop app",
  "main": "out/main/index.js",
  "type": "module",
  "engines": {
    "node": ">=20.11.1"
  },
  "scripts": {
    "predev": "npm run rebuild:native",
    "dev": "electron-vite dev",
    "build": "electron-vite build && npm run build:copy-migrations",
    "prepare:native:win": "node scripts/prepare-native-win.cjs",
    "rebuild:native": "npm run prepare:native:win && electron-builder install-app-deps",
    "dist:win": "npm run build && electron-builder --win nsis --publish never",
    "publish:win": "npm run build && electron-builder --win nsis --publish always",
    "build:copy-migrations": "node scripts/copy-main-migrations.cjs",
    "preview": "electron-vite preview",
    "seed:sample": "electron scripts/seed-sample.cjs",
    "test": "node scripts/run-tests.cjs",
    "test:vitest": "vitest run --pool=forks",
    "test:smoke:build": "npm run build && node scripts/smoke-built-startup.cjs",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p src/renderer/tsconfig.json",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "dependencies": {
    "@google/genai": "^1.18.0",
    "better-sqlite3": "^11.10.0",
    "dotenv": "^16.4.5",
    "electron-updater": "^6.7.3",
    "playwright": "^1.58.2",
    "prismjs": "^1.30.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "react-simple-code-editor": "^0.14.1",
    "react-toastify": "^11.0.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.1",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "@vitejs/plugin-react": "^4.3.3",
    "electron": "^33.2.0",
    "electron-builder": "^26.7.0",
    "electron-vite": "^2.3.0",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.4.1",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.15.0",
    "vite": "^5.4.11",
    "vitest": "^1.6.0"
  },
  "build": {
    "appId": "com.qaassistant.app",
    "productName": "QA Assistant",
    "directories": {
      "output": "dist"
    },
    "npmRebuild": false,
    "nodeGypRebuild": false,
    "files": [
      "out/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/*.node"
    ],
    "extraResources": [
      {
        "from": "out/renderer/step-guide.html",
        "to": "step-guide.html"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "TomasNiDo",
        "repo": "qa-assistant"
      }
    ]
  }
}
